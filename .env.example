# ==============================================================
# Tickora — Production Environment Variables Template
# ==============================================================
# Copy this file, fill in values, and set them in your host
# (Railway for backend, Vercel for frontend)
# ==============================================================

# ---- BACKEND (Railway) ----------------------------------------

# NeonDB connection string (get from neon.tech dashboard)
DATABASE_URL=postgres://tickora_owner:<password>@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# Generate a strong random secret: openssl rand -hex 32
JWT_SECRET=change_me_to_a_strong_secret

# Railway sets PORT automatically — leave as 8080 for local
PORT=8080

# ---- FRONTEND (Vercel) ----------------------------------------

# Your Railway backend URL after first deployment
NEXT_PUBLIC_API_URL=https://tickora-backend.up.railway.app
